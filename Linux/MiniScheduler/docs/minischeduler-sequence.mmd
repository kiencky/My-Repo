
sequenceDiagram
    autonumber
    participant U as User
    participant C as CLI Client
    participant D as Daemon
    participant IPC as Unix Socket
    participant Q as Job Queue
    participant W as Worker
    participant EX as Executor
    participant S as State Store
    participant L as Log

    rect rgb(245,245,245)
    Note over U,D: Startup
    U->>D: start daemon
    D->>D: load config
    D->>IPC: create, bind, listen
    D->>Q: init queue
    D->>W: spawn N workers
    W-->>D: ready
    D->>L: log daemon started
    end

    rect rgb(245,245,245)
    Note over U,D: Add Job (happy path)
    U->>C: add "command"
    C->>D: AddJobRequest
    D->>D: validate request
    D->>Q: enqueue(job=PENDING)
    D->>S: persist metadata
    D->>L: log accepted
    D-->>C: AddJobResponse(job_id)
    C-->>U: show job_id

    W->>Q: dequeue
    W->>S: state PENDING->RUNNING
    W->>L: log running
    W->>EX: exec command
    EX-->>W: exit code
    alt exit code == 0
        W->>S: state RUNNING->DONE
        W->>L: log done
    else exit code != 0
        W->>S: state RUNNING->FAILED
        W->>L: log failed
    end
    end

    rect rgb(245,245,245)
    Note over U,D: Status
    U->>C: status
    C->>D: StatusRequest
    D->>S: read snapshot
    S-->>D: jobs + stats
    D-->>C: StatusResponse
    C-->>U: render table
    end

    rect rgb(245,245,245)
    Note over U,D: Shutdown
    U->>C: stop
    C->>D: ShutdownRequest
    D->>D: set shutting_down=true
    D->>L: log shutdown started
    D->>IPC: stop accepting new add
    D->>W: wait running jobs (grace period)
    alt all jobs finished in time
        W-->>D: workers idle
    else timeout
        D->>W: terminate remaining workers
    end
    D->>S: flush state
    D->>IPC: close and unlink socket
    D->>L: log shutdown completed
    D-->>C: ShutdownAck
    C-->>U: daemon stopped
    end

    rect rgb(255,245,245)
    Note over C,D: Add Job failure paths
    C->>D: AddJobRequest
    alt malformed request
        D->>L: warn invalid request
        D-->>C: Error(INVALID_REQUEST)
    else queue full
        D->>Q: enqueue attempt
        Q-->>D: reject(full)
        D->>L: warn queue full
        D-->>C: Error(QUEUE_FULL)
    else daemon busy
        D->>L: error server busy
        D-->>C: Error(SERVER_BUSY)
    end
    end
